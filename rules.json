[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "removeHeaders",
      "responseHeaders": [
        "x-frame-options",
        "content-security-policy",
        "content-security-policy-report-only",
        "frame-options"
      ]
    },
    "condition": {
      "urlFilter": "*",
      "resourceTypes": [
        "sub_frame",
        "xmlhttprequest",
        "image",
        "script",
        "stylesheet",
        "font",
        "media"
      ]
    }
  },
  {
    "id": 2,
    "priority": 2,
    "action": {
      "type": "modifyHeaders",
      "responseHeaders": [
        {
          "header": "access-control-allow-origin",
          "operation": "set",
          "value": "*"
        },
        {
          "header": "access-control-allow-credentials",
          "operation": "set",
          "value": "true"
        }
      ]
    },
    "condition": {
      "urlFilter": "*",
      "resourceTypes": [
        "sub_frame",
        "xmlhttprequest",
        "image",
        "script",
        "stylesheet",
        "font",
        "media"
      ]
    }
  }
]