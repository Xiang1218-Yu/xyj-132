{
  "manifest_version": 3,
  "name": "QuickLink Preview",
  "version": "2.0.0",
  "description": "快速预览网页链接 - 悬停或点击链接即可弹窗预览网站、视频、音乐等内容，支持批量预览、自定义主题、安全评估、收藏管理和数字快捷键",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "QuickLink Preview 设置",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/01-config.js",
        "content/02-utils.js",
        "content/03-security.js",
        "content/04-link-types.js",
        "content/05-theme.js",
        "content/06-positioning.js",
        "content/07-loaders.js",
        "content/08-preview-panel.js",
        "content/09-batch-mode.js",
        "content/10-qrcode.js",
        "content/11-shortcuts.js",
        "content/12-favorites.js",
        "content/13-main.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/content.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
